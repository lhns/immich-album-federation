# Database
IMMICH_SYNC_DB_URL=jdbc:postgresql://127.0.0.1:5432/immich_sync
IMMICH_SYNC_DB_USER=immich_sync
IMMICH_SYNC_DB_PASSWORD=replace_me
# Migrations ship inside the jar; override only for development
#IMMICH_SYNC_MIGRATION_LOCATIONS=classpath:db/migration

# Topology config file (peers + optional manual pairs), see doc/sync.example.yaml
IMMICH_SYNC_CONFIG=./sync.yaml

# One API key env var per peer, referenced by apiKeyEnv in the config file.
# Each key belongs to that instance's dedicated sync user.
IMMICH_SOURCE_API_KEY=replace_me
IMMICH_TARGET_API_KEY=replace_me

# Safety (defaults are already strict)
IMMICH_SYNC_ALLOWED_HOSTS=localhost,127.0.0.1,host.docker.internal
IMMICH_SYNC_BLOCKED_HOSTS=
IMMICH_SYNC_ALLOW_PRIVATE_NETWORKS=true

# Mass-removal circuit breaker (per side, per run). A breach quarantines the pair
# until it is re-armed with --rearm=<pair-name>.
IMMICH_SYNC_MAX_REMOVALS=25
IMMICH_SYNC_MAX_REMOVAL_FRACTION=0.3

# Retention: album-state snapshots are kept for the newest K runs per pair (the
# baseline is never pruned); runs/events/resolved tombstones are pruned after N days
# (0 = keep forever). uploaded_asset and deletion_log are never pruned.
IMMICH_SYNC_OBSERVATION_KEEP_RUNS=5
IMMICH_SYNC_AUDIT_RETENTION_DAYS=90

# Concurrency
IMMICH_SYNC_PAIR_CONCURRENCY=2
IMMICH_SYNC_TRANSFER_CONCURRENCY=3

# Required when running with --apply
IMMICH_ENABLE_WRITES=YES_I_KNOW
